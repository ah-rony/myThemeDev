{% comment %}
  Snippet: countdown-timer.liquid
  Usage:
    {% render 'countdown-timer',
      end_date: section.settings.end_date,
      end_time: section.settings.end_time,
      timer_id: section.id
    %}
{% endcomment %}

<div class="countdown" role="timer" aria-label="Sale countdown" id="countdown-{{ timer_id }}">
  <div class="countdown-unit">
    <span class="digits" data-cd-days>00</span>
    <span class="unit-label">D</span>
  </div>
  <div class="countdown-unit">
    <span class="digits" data-cd-hours>00</span>
    <span class="unit-label">Hr</span>
  </div>
  <div class="countdown-unit">
    <span class="digits" data-cd-mins>00</span>
    <span class="unit-label">Min</span>
  </div>
  <div class="countdown-unit">
    <span class="digits" data-cd-secs>00</span>
    <span class="unit-label">Sec</span>
  </div>
</div>

<script>
(function () {
  var wrap = document.getElementById('countdown-{{ timer_id }}');
  if (!wrap) return;

  {% if end_date != blank %}
    {% assign date_str = end_date | append: 'T' | append: end_time | default: '00:00' %}
    var END = new Date('{{ date_str }}');
  {% else %}
    var END = new Date(Date.now() + 5 * 24 * 60 * 60 * 1000);
  {% endif %}

  var elD = wrap.querySelector('[data-cd-days]');
  var elH = wrap.querySelector('[data-cd-hours]');
  var elM = wrap.querySelector('[data-cd-mins]');
  var elS = wrap.querySelector('[data-cd-secs]');

  function pad(n) { return String(n).padStart(2, '0'); }

  function tick() {
    var diff  = Math.max(0, END - Date.now());
    var total = Math.floor(diff / 1000);
    elD.textContent = pad(Math.floor(total / 86400));
    elH.textContent = pad(Math.floor((total % 86400) / 3600));
    elM.textContent = pad(Math.floor((total % 3600) / 60));
    elS.textContent = pad(total % 60);
    if (diff <= 0) {
      clearInterval(timer);
      wrap.setAttribute('aria-label', 'Sale has ended');
    }
  }

  tick();
  var timer = setInterval(tick, 1000);
}());
</script>