<style>

.image-swatches {
  display: flex;
  gap: 6px;
  margin-top: 8px;
}

.image-swatch {
  width: 40px;
  height: 40px;
  border: 1px solid #ccc;
  overflow: hidden;
  cursor: pointer;
}

.image-swatch img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.color-swatches {
  display: flex;
  gap: 6px;
  margin-top: 8px;
}

.color-swatch {
  width: 18px;
  height: 18px;
  /* border-radius: 50%; */
  border: 1px solid #ccc;
  cursor: pointer;
}

/* ACTIVE */


.image-swatches,
.color-swatches {
  display: flex;
  gap: 8px; 
  margin: 10px 5px;
}

.image-swatch {
  width: 42px;
  height: 42px;
  padding: 2px; 
  background: #fff;
  cursor: pointer;
  box-sizing: border-box;
}

.image-swatch img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 4px;
  display: block;
}

.image-swatch.active,.color-swatch.active {
  outline: 2px solid black;
  outline-offset: 2px;
}
</style>



<div class="product-card" data-product-id="{{ product.id }}">

  <a href="{{ product.url }}">
    <img
      class="product-main-image"
      src="{{ product.featured_image | image_url: width: 500 }}"
      width="500"
      height="500"
      alt="{{ product.title }}"
    >
  </a>

  <h3>{{ product.title }}</h3>
  <p>{{ product.price | money }}</p>

  {% assign option_index = nil %}

  {% for option in product.options_with_values %}
    {% if option.name == 'Color' or option.name == 'Colour' %}
      {% assign option_index = forloop.index0 %}
    {% endif %}
  {% endfor %}

  {% if option_index != nil %}

    <div class="{% if switch_type == 'color' %}color-swatches{% else %}image-swatches{% endif %}">

      {% assign shown = '' %}

      {% for variant in product.variants %}

        {% assign value = variant.options[option_index] %}

        {% unless shown contains value %}

          <button
            class="{% if switch_type == 'color' %}color-swatch{% else %}image-swatch{% endif %}"
            data-image="{{ variant.featured_image | image_url: width: 500 }}"
            data-color="{{ value }}"
            title="{{ value }}"
            {% if switch_type == 'color' %}
              style="background-color: {{ value | downcase }}"
            {% endif %}
          >

            {% if switch_type == 'image' and variant.featured_image %}
              {% comment %} <img
                src="{{ variant.featured_image | image_url: width: 100 }}"
                alt="{{ value }}"
              > {% endcomment %}

               {{ variant.featured_image 
                  | image_url: width: 100 
                  | image_tag: alt: value 
                }} 
            {% endif %}

          </button>

          {% assign shown = shown | append: value | append: ',' %}

        {% endunless %}

      {% endfor %}

    </div>

  {% endif %}

</div>

