{{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}
{{ 'rico-testimonials.css' | asset_url | stylesheet_tag }}

<section
  class="sop-testimonials color-{{ section.settings.color_schemes }}"
  data-loop="{{ section.settings.loop }}"
  data-autoplay="{{ section.settings.autoplay }}"
  data-autoplay-delay="{{ section.settings.autoplay_delay }}"
  data-speed="{{ section.settings.transition_speed }}"
  style="
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    margin-top: {{ section.settings.margin_top }}px;
    margin-bottom: {{ section.settings.margin_bottom }}px;
  "
>

  <div class="sop-testimonials__container container-fluid">

    <div class="sop-testimonials__top row align-center justify-between">

      <div class="sop-testimonials__top-left col-auto">

        <div class="sop-testimonials__quote-icon" aria-hidden="true">
          <svg viewBox="0 0 100 73" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M0 46.98H25.42L17.095 64.037V72.08L46.98 46.98V0H0L0 46.98Z" fill="currentColor"/>
            <path d="M61.6494 8.8623V46.9803H82.2734L75.5174 60.8203V67.3433L99.7644 46.9803V8.8623H61.6494Z" fill="currentColor"/>
          </svg>
        </div>

      </div>

      {% if section.blocks.size > 1 %}
        <div class="sop-testimonials__top-right col-auto">

          <div class="sop-testimonials__nav" role="group" aria-label="Testimonial navigation">

            <button class="sop-testimonials__btn sop-testimonials__prev" aria-label="Previous testimonial" type="button">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <path d="M22 11H4.414l5.293-5.293a1 1 0 1 0-1.414-1.414l-7 7a1 1 0 0 0 0 1.414l7 7a1 1 0 0 0 1.414-1.414L4.414 13H22a1 1 0 0 0 0-2z"/>
              </svg>
            </button>

            <button class="sop-testimonials__btn sop-testimonials__next" aria-label="Next testimonial" type="button">
              <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
                <path d="M22 11H4.414l5.293-5.293a1 1 0 1 0-1.414-1.414l-7 7a1 1 0 0 0 0 1.414l7 7a1 1 0 0 0 1.414-1.414L4.414 13H22a1 1 0 0 0 0-2z"/>
              </svg>
            </button>

          </div>

        </div>
      {% endif %}

    </div>

    {% if section.blocks.size > 0 %}

      <div class="row">
        <div class="col-12">

          <div class="swiper sop-testimonials__swiper" aria-live="polite" aria-atomic="false">

            <div class="swiper-wrapper">

              {% for block in section.blocks %}
                {% if block.type == 'testimonial' %}

                  <div
                    class="swiper-slide"
                    {{ block.shopify_attributes }}
                  >

                    <div class="sop-testimonials__slide-inner">

                      {% if block.settings.quote != blank %}
                        <blockquote class="sop-testimonials__quote" itemprop="reviewBody">
                          {{ block.settings.quote | escape }}
                        </blockquote>
                      {% endif %}

                      {% if block.settings.author != blank %}
                        <p class="sop-testimonials__author">

                          <span itemprop="name">
                            {{ block.settings.author | escape }}
                          </span>

                          {% if block.settings.author_title != blank %}
                            <span class="sop-testimonials__author-title">
                              ({{ block.settings.author_title | escape }})
                            </span>
                          {% endif %}

                        </p>
                      {% endif %}

                    </div>

                  </div>

                {% endif %}
              {% endfor %}

            </div>

          </div>

        </div>
      </div>

      {% if section.blocks.size > 1 %}
        <div class="row justify-center">
          <div class="col-auto">
            <div class="sop-testimonials__pagination-wrap" aria-hidden="true">
              <div class="swiper-pagination sop-testimonials__pagination"></div>
            </div>
          </div>
        </div>
      {% endif %}

    {% else %}

      <div class="row justify-center">
        <div class="col-12">
          <p class="sop-testimonials__empty">
            Add testimonial blocks in the theme editor.
          </p>
        </div>
      </div>

    {% endif %}

  </div>

</section>

<script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
<script src="{{ 'rico-testimonials.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section-testimonials",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_schemes",
      "label": "Color scheme",
      "default": "default"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Margin top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Margin bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Slider"
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Enable autoplay",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_delay",
      "label": "Autoplay delay",
      "min": 2000,
      "max": 9000,
      "step": 500,
      "unit": "ms",
      "default": 4000
    },
    {
      "type": "range",
      "id": "transition_speed",
      "label": "Transition speed",
      "min": 200,
      "max": 1200,
      "step": 100,
      "unit": "ms",
      "default": 600
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Enable loop",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "limit": 10,
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "From busy city days to slow weekend walks, these sneakers keep up effortlessly. I don't think about comfort anymore — it's just there."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Maya R."
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author title",
          "default": "Weekend Wanderer"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        },
        {
          "type": "testimonial"
        }
      ]
    }
  ]
}
{% endschema %}