{% liquid
  assign sop_product = section.settings.product | default: product
  assign sop_radius = section.settings.card_radius
  assign sop_cv = sop_product.selected_or_first_available_variant
%}

<section class="sop-weekly-winner">
  <div class="container">
    <div class="row g-4 align-start">

      <div class="col-12 col-md-7 col-lg-7 sop-gallery">
        {% for image in sop_product.images %}
          <div class="sop-image-wrap">
            <div class="sop-image">
              {{
                image
                | image_url: width: 2000
                | image_tag:
                  loading: 'lazy',
                  alt: image.alt | default: sop_product.title,
                  widths: '600,900,1200,1600,2000'
              }}
            </div>
          </div>
        {% endfor %}
      </div>

      <div class="col-12 col-md-5 col-lg-5 sop-sidebar">
        <div class="sop-sidebar-inner">

          {% for block in section.blocks %}
            {% case block.type %}

              {% when 'title' %}
                <div class="sop-block" {{ block.shopify_attributes }}>
                  {% if block.settings.show_vendor and sop_product.vendor != blank %}
                    <p class="sop-vendor">{{ sop_product.vendor }}</p>
                  {% endif %}

                  <div class="sop-title-wrap">
                    <span class="sop-title">{{ sop_product.title }}</span>
                  </div>

                  {% if block.settings.show_sku and sop_cv.sku != blank %}
                    <p class="sop-sku">SKU: {{ sop_cv.sku }}</p>
                  {% endif %}
                </div>

              {% when 'price' %}
                <div class="sop-block" {{ block.shopify_attributes }}>
                  <div class="sop-price-wrap">
                    <span class="sop-price">{{ sop_cv.price | money }}</span>

                    {% if sop_cv.compare_at_price > sop_cv.price %}
                      <span class="sop-compare-price">{{ sop_cv.compare_at_price | money }}</span>

                      {% if block.settings.show_savings %}
                        {% assign saved = sop_cv.compare_at_price | minus: sop_cv.price %}
                        <span class="sop-savings">Save {{ saved | money }}</span>
                      {% endif %}
                    {% endif %}
                  </div>

                  {% if block.settings.show_tax_note %}
                    <p class="sop-tax-note">{{ block.settings.tax_note_text }}</p>
                  {% endif %}
                </div>

              {% when 'countdown' %}
                <div class="sop-block" {{ block.shopify_attributes }}>
                  <div class="sop-countdown">

                    <div class="sop-countdown-left">

                      {% if block.settings.heading != blank %}
                        <div class="sop-countdown-heading">
                          {{ block.settings.heading }}
                        </div>
                      {% endif %}

                      {% if block.settings.badge != blank %}
                        <div class="sop-badge-wrap">

                          <span class="sop-badge-text">
                            {{ block.settings.badge }}
                          </span>

                          <button
                            type="button"
                            class="sop-copy-btn"
                            data-copy="{{ block.settings.badge }}"
                          >
                            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <rect x="9" y="9" width="13" height="13" rx="2"/>
                              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/>
                            </svg>
                            Copy
                          </button>

                        </div>
                      {% endif %}

                    </div>

                    <div
                      class="sop-timer"
                      data-days="{{ block.settings.days }}"
                      data-hours="{{ block.settings.hours }}"
                      data-mins="{{ block.settings.minutes }}"
                      data-secs="{{ block.settings.seconds }}"
                    >

                      <div class="sop-time-box">
                        <span class="sop-days">00</span>
                        <small>{{ block.settings.days_label }}</small>
                      </div>

                      <div class="sop-time-box">
                        <span class="sop-hours">00</span>
                        <small>{{ block.settings.hours_label }}</small>
                      </div>

                      <div class="sop-time-box">
                        <span class="sop-mins">00</span>
                        <small>{{ block.settings.minutes_label }}</small>
                      </div>

                      <div class="sop-time-box">
                        <span class="sop-secs">00</span>
                        <small>{{ block.settings.seconds_label }}</small>
                      </div>

                    </div>

                  </div>
                </div>

              {% when 'siblings' %}
                {% if block.settings.collection != blank %}
                  <div class="sop-block" {{ block.shopify_attributes }}>

                    {% if block.settings.heading != blank %}
                      <div class="sop-label">{{ block.settings.heading }}</div>
                    {% endif %}

                    <div class="sop-sibling-list">
                      {% for sibling in collections[block.settings.collection].products limit: 12 %}
                        <a
                          href="{{ sibling.url }}"
                          class="sop-sibling {% if sibling.id == sop_product.id %}active{% endif %}"
                          title="{{ sibling.title }}"
                        >
                          {% if sibling.featured_image %}
                            {{
                              sibling.featured_image
                              | image_url: width: 160
                              | image_tag: loading: 'lazy', alt: sibling.title
                            }}
                          {% endif %}
                        </a>
                      {% endfor %}
                    </div>

                  </div>
                {% endif %}

              {% when 'size_picker' %}
                {% assign size_option = blank %}

                {% for option in sop_product.options_with_values %}
                  {% assign option_name = option.name | downcase %}

                  {% if option_name contains 'size' %}
                    {% assign size_option = option %}
                  {% endif %}
                {% endfor %}

                {% if size_option != blank %}
                  <div class="sop-block" {{ block.shopify_attributes }}>

                    <div class="sop-size-top">

                      <div class="sop-label sop-label--no-margin">
                        {{ block.settings.heading }}
                      </div>

                      {% if block.settings.enable_size_guide %}
                        <button
                          type="button"
                          class="sop-size-guide-btn"
                          id="sop-open-size-guide"
                        >
                          <svg width="14" height="10" viewBox="0 0 14 10" fill="none" stroke="currentColor" stroke-width="1.5">
                            <path d="M1 5h12M9 1l4 4-4 4"/>
                            <path d="M5 1L1 5l4 4"/>
                          </svg>

                          {{ block.settings.size_guide_text }}
                        </button>
                      {% endif %}

                    </div>

                    <div class="sop-size-list">
                      {% for value in size_option.values %}

                        {% assign available = false %}

                        {% for variant in sop_product.variants %}
                          {% if variant.options contains value and variant.available %}
                            {% assign available = true %}
                          {% endif %}
                        {% endfor %}

                        <button
                          type="button"
                          class="sop-size-btn {% if sop_cv.options contains value %}active{% endif %} {% unless available %}sold-out{% endunless %}"
                        >
                          {{ value }}
                        </button>

                      {% endfor %}
                    </div>

                  </div>
                {% endif %}

              {% when 'variant_picker' %}
                {% for option in sop_product.options_with_values %}
                  {% assign option_name = option.name | downcase %}

                  {% unless option_name contains 'size' %}
                    <div class="sop-block" {{ block.shopify_attributes }}>

                      <div class="sop-label">{{ option.name }}</div>

                      <div class="sop-variant-list">

                        {% for value in option.values %}

                          {% assign available = false %}

                          {% for variant in sop_product.variants %}
                            {% if variant.options contains value and variant.available %}
                              {% assign available = true %}
                            {% endif %}
                          {% endfor %}

                          <button
                            type="button"
                            class="sop-variant-btn {% if sop_cv.options contains value %}active{% endif %} {% unless available %}sold-out{% endunless %}"
                          >
                            {{ value }}
                          </button>

                        {% endfor %}

                      </div>

                    </div>
                  {% endunless %}
                {% endfor %}

              {% when 'add_to_cart' %}
                <div class="sop-block" {{ block.shopify_attributes }}>

                  {% form 'product', sop_product, id: 'sop-product-form' %}

                    <input type="hidden" name="id" value="{{ sop_cv.id }}">

                    <div class="sop-atc-row">

                      <div class="sop-qty-wrap">
                        <button type="button" class="sop-qty-btn sop-minus">−</button>

                        <input
                          type="number"
                          class="sop-qty-input"
                          value="1"
                          min="1"
                        >

                        <button type="button" class="sop-qty-btn sop-plus">+</button>
                      </div>

                      <button type="submit" class="sop-atc-btn">
                        {{ block.settings.button_text }}
                      </button>

                    </div>

                    {% if block.settings.show_dynamic_checkout %}
                      <div class="sop-dynamic-checkout">
                        {{ form | payment_button }}
                      </div>
                    {% endif %}

                  {% endform %}

                </div>

              {% when 'buy_now' %}
                <div class="sop-block" {{ block.shopify_attributes }}>
                  <button type="button" class="sop-buy-now-btn">
                    {{ block.settings.button_text }}
                  </button>
                </div>

              {% comment %} {% when 'stock_urgency' %}
                {% assign stock_qty = sop_cv.inventory_quantity %}

                <div class="sop-block" {{ block.shopify_attributes }}>
                  <div class="sop-stock-wrap">

                    <div class="sop-stock-top">
                      <span class="sop-stock-text">
                        {{ block.settings.prefix }}
                        <strong>{{ stock_qty }}</strong>
                        {{ block.settings.suffix }}
                      </span>
                    </div>

                    <div class="sop-stock-bar">
                      <div
                        class="sop-stock-fill"
                        style="width:{% if stock_qty > 100 %}100{% else %}{{ stock_qty }}{% endif %}%"
                      ></div>
                    </div>

                  </div>
                </div> {% endcomment %}

                {% when 'stock_urgency' %}
                  {% assign stock_qty = sop_cv.inventory_quantity %}

                  <div class="sop-block" {{ block.shopify_attributes }}>

                    <div class="sop-stock-wrap">

                      <div class="sop-stock-heading">
                        Hurry, only <strong>{{ stock_qty }}</strong> items left in stock!
                      </div>

                      <div class="sop-stock-progress">

                        <span class="sop-stock-icon">
                          <svg
                            width="18"
                            height="18"
                            viewBox="0 0 24 24"
                            fill="currentColor"
                            xmlns="http://www.w3.org/2000/svg"
                          >
                            <path d="M13 2L4 14H11L10 22L20 9H13L13 2Z"/>
                          </svg>
                        </span>

                        <div class="sop-stock-bar">
                          <div
                            class="sop-stock-fill"
                            style="width:{% if stock_qty > 10 %}90{% else %}{{ stock_qty | times: 9 }}{% endif %}%"
                          ></div>
                        </div>

                      </div>

                    </div>

                  </div>




              {% comment %} {% when 'pickup' %}
                <div class="sop-block" {{ block.shopify_attributes }}>
                  <div class="sop-pickup-wrap">

                    {% if block.settings.heading != blank %}
                      <div class="sop-pickup-heading">
                        {{ block.settings.heading }}
                      </div>
                    {% endif %}

                    <div class="sop-pickup-stores">

                      {% for i in (1..4) %}
                        {% assign name_key = 'store_' | append: i %}
                        {% assign avail_key = 'store_' | append: i | append: '_available' %}

                        {% assign store_name = block.settings[name_key] %}
                        {% assign store_avail = block.settings[avail_key] %}

                        {% if store_name != blank %}
                          <div class="sop-pickup-row">
                            <span class="sop-dot {% if store_avail %}sop-dot--on{% else %}sop-dot--off{% endif %}"></span>
                            <span>{{ store_name }}</span>
                          </div>
                        {% endif %}
                      {% endfor %}

                    </div>

                    <div class="sop-pickup-footer">

                      {% if block.settings.note != blank %}
                        <span class="sop-pickup-note">
                          {{ block.settings.note }}
                        </span>
                      {% endif %}

                      {% if block.settings.link_text != blank %}
                        <a href="{{ block.settings.link_url }}" class="sop-pickup-link">
                          {{ block.settings.link_text }}
                        </a>
                      {% endif %}

                    </div>

                  </div>
                </div> {% endcomment %}


                {% when 'pickup' %}
                  <div class="sop-block" {{ block.shopify_attributes }}>
                    <div class="sop-pickup-wrap">

                      {% if block.settings.heading != blank %}
                        <div class="sop-pickup-heading-wrap">
                          <span class="sop-pickup-heading">
                            {{ block.settings.heading }}
                          </span>
                        </div>
                      {% endif %}

                      <div class="sop-pickup-stores">

                        {% for i in (1..4) %}
                          {% assign name_key = 'store_' | append: i %}
                          {% assign avail_key = 'store_' | append: i | append: '_available' %}

                          {% assign store_name = block.settings[name_key] %}
                          {% assign store_avail = block.settings[avail_key] %}

                          {% if store_name != blank %}
                            <div class="sop-pickup-row">

                              {% if store_avail %}
                                <span class="sop-pickup-icon">
                                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">

                                    <path
                                      d="
                                        M12 1
                                        C13 1 13.6 2.2 14.4 2.4
                                        C15.3 2.7 16.3 2 17 2.5
                                        C17.8 3 17.7 4.3 18.3 5
                                        C19 5.7 20.3 5.6 20.8 6.4
                                        C21.3 7.1 20.7 8.2 21 9.1
                                        C21.2 10 22.4 10.6 22.4 11.5
                                        C22.4 12.4 21.2 13 21 13.9
                                        C20.7 14.8 21.3 15.9 20.8 16.6
                                        C20.3 17.4 19 17.3 18.3 18
                                        C17.7 18.7 17.8 20 17 20.5
                                        C16.3 21 15.3 20.3 14.4 20.6
                                        C13.6 20.8 13 22 12 22
                                        C11 22 10.4 20.8 9.6 20.6
                                        C8.7 20.3 7.7 21 7 20.5
                                        C6.2 20 6.3 18.7 5.7 18
                                        C5 17.3 3.7 17.4 3.2 16.6
                                        C2.7 15.9 3.3 14.8 3 13.9
                                        C2.8 13 1.6 12.4 1.6 11.5
                                        C1.6 10.6 2.8 10 3 9.1
                                        C3.3 8.2 2.7 7.1 3.2 6.4
                                        C3.7 5.6 5 5.7 5.7 5
                                        C6.3 4.3 6.2 3 7 2.5
                                        C7.7 2 8.7 2.7 9.6 2.4
                                        C10.4 2.2 11 1 12 1
                                        Z
                                      "
                                      fill="#000"
                                    />

                                    <circle cx="12" cy="12" r="7.2" fill="#000"/>

                                    <path
                                      d="M8 12.2L10.7 14.8L16.2 9.3"
                                      stroke="white"
                                      stroke-width="2"
                                      stroke-linecap="round"
                                      stroke-linejoin="round"
                                    />

                                  </svg>
                                </span>
                              {% else %}
                                <span class="sop-pickup-icon">
                                  <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                                  <path
                                    d="
                                      M12 1
                                      C13 1 13.6 2.2 14.4 2.4
                                      C15.3 2.7 16.3 2 17 2.5
                                      C17.8 3 17.7 4.3 18.3 5
                                      C19 5.7 20.3 5.6 20.8 6.4
                                      C21.3 7.1 20.7 8.2 21 9.1
                                      C21.2 10 22.4 10.6 22.4 11.5
                                      C22.4 12.4 21.2 13 21 13.9
                                      C20.7 14.8 21.3 15.9 20.8 16.6
                                      C20.3 17.4 19 17.3 18.3 18
                                      C17.7 18.7 17.8 20 17 20.5
                                      C16.3 21 15.3 20.3 14.4 20.6
                                      C13.6 20.8 13 22 12 22
                                      C11 22 10.4 20.8 9.6 20.6
                                      C8.7 20.3 7.7 21 7 20.5
                                      C6.2 20 6.3 18.7 5.7 18
                                      C5 17.3 3.7 17.4 3.2 16.6
                                      C2.7 15.9 3.3 14.8 3 13.9
                                      C2.8 13 1.6 12.4 1.6 11.5
                                      C1.6 10.6 2.8 10 3 9.1
                                      C3.3 8.2 2.7 7.1 3.2 6.4
                                      C3.7 5.6 5 5.7 5.7 5
                                      C6.3 4.3 6.2 3 7 2.5
                                      C7.7 2 8.7 2.7 9.6 2.4
                                      C10.4 2.2 11 1 12 1
                                      Z
                                    "
                                    fill="#D93025"
                                  />

                                  <!-- X icon -->
                                  <path
                                    d="M8 8L16 16"
                                    stroke="white"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                  />

                                  <path
                                    d="M16 8L8 16"
                                    stroke="white"
                                    stroke-width="2"
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                  />

                                </svg>
                                </span>
                              {% endif %}

                              <span class="sop-pickup-store-name">
                                {{ store_name }}
                              </span>

                            </div>
                          {% endif %}
                        {% endfor %}

                      </div>

                      <div class="sop-pickup-footer">

                        {% if block.settings.note != blank %}
                          <div class="sop-pickup-note">
                            {{ block.settings.note }}
                          </div>
                        {% endif %}

                        {% if block.settings.link_text != blank %}
                          <a href="{{ block.settings.link_url }}" class="sop-pickup-link">
                            {{ block.settings.link_text }}
                          </a>
                        {% endif %}

                      </div>

                    </div>
                  </div>







              {% when 'description' %}
                {% if sop_product.description != blank %}
                  <div class="sop-accordion" {{ block.shopify_attributes }}>

                    <button type="button" class="sop-accordion-btn">
                      <span>{{ block.settings.heading }}</span>
                      <span class="sop-accord-icon">+</span>
                    </button>

                    <div class="sop-accordion-body">
                      <div class="sop-rte">
                        {{ sop_product.description }}
                      </div>
                    </div>

                  </div>
                {% endif %}

              {% when 'collapsible_tab' %}
                <div class="sop-accordion" {{ block.shopify_attributes }}>  

                  <button type="button" class="sop-accordion-btn">
                    <span class="sop-accord-text">{{ block.settings.heading }}</span>
                    <span class="sop-accord-icon">+</span>
                  </button>

                  <div class="sop-accordion-body">
                    <div class="sop-rte">
                      {{ block.settings.content }}
                    </div>
                  </div>

                </div>

              {% when 'upsell' %}
                {% assign upsell = all_products[block.settings.product] %}
                {% assign upsell_cv = upsell.selected_or_first_available_variant %}

                {% if upsell != blank %}
                  <div class="sop-upsell" {{ block.shopify_attributes }}>

                    {% if block.settings.heading != blank %}
                      <div class="sop-label">{{ block.settings.heading }}</div>
                    {% endif %}

                    <div class="sop-upsell-card">

                      <div class="sop-upsell-image">
                        {% if upsell.featured_image %}
                          {{
                            upsell.featured_image
                            | image_url: width: 300
                            | image_tag: loading: 'lazy', alt: upsell.title
                          }}
                        {% endif %}
                      </div>

                      <div class="sop-upsell-content">

                        <div class="sop-upsell-title">
                          {{ upsell.title }}
                        </div>

                        <div class="sop-upsell-prices">

                          {% if upsell_cv.compare_at_price > upsell_cv.price %}
                            <del class="sop-upsell-compare">
                              {{ upsell_cv.compare_at_price | money }}
                            </del>
                          {% endif %}

                          <span class="sop-upsell-price">
                            {{ upsell_cv.price | money }}
                          </span>

                        </div>

                      </div>

                      <button
                        type="button"
                        class="sop-upsell-btn"
                        data-variant-id="{{ upsell_cv.id }}"
                      >
                        {{ block.settings.button_text }}
                      </button>

                    </div>

                  </div>
                {% endif %}

            {% endcase %}
          {% endfor %}

        </div>
      </div>

    </div>
  </div>

  <div class="sop-size-overlay"></div>

  <div class="sop-size-drawer">

    <div class="sop-size-header">
      <h3>{{ section.settings.size_drawer_title }}</h3>

      <button type="button" class="sop-close-drawer">
        ✕
      </button>
    </div>

    <div class="sop-size-content">

      {% if section.settings.size_guide_image != blank %}
        {{
          section.settings.size_guide_image
          | image_url: width: 1400
          | image_tag: loading: 'lazy', alt: 'Size Guide'
        }}
      {% endif %}

      {% if section.settings.size_guide_content != blank %}
        <div class="sop-rte">
          {{ section.settings.size_guide_content }}
        </div>
      {% endif %}

    </div>

  </div>



  <div class="sop-zoom-cursor" id="sop-zoom-cursor">
  {{ section.settings.zoom_cursor_text }}
</div>



</section>

<style>
*{
  box-sizing:border-box;
}

.sop-weekly-winner{
  padding:24px 0;
}

.sop-gallery{
  display:flex;
  flex-direction:column;
}

.sop-image-wrap{
  border-radius:{{ sop_radius }}px;
  overflow:hidden;
  background:#f5f5f5;
}

.sop-image img{
  width:100%;
  display:block;
}

.sop-sidebar-inner{
  display:flex;
  flex-direction:column;
  gap:24px;
}

.sop-label{
  font-size:16px;
  font-weight:500;
  margin-bottom:16px;
}

.sop-label--no-margin{
  margin-bottom:0;
}

.sop-vendor{
  font-size:11px;
  font-weight:600;
  text-transform:uppercase;
  letter-spacing:.1em;
  color:#999;
  margin-bottom:6px;
}

.sop-title-wrap{
  display:flex;
  align-items:center;
  gap:16px;
}

.sop-title{
  margin:0;
  font-size:24px;
  line-height:100%;
  font-weight:400;
  white-space:nowrap;
}

.sop-sku{
  font-size:11px;
  color:#bbb;
  margin-top:6px;
}

.sop-price-wrap{
  display:flex;
  align-items:center;
  flex-wrap:wrap;
  gap:10px;
}

.sop-price{
  font-size:20px;
  font-weight:400;
  color:#1C1C1CCC;
}

.sop-compare-price{
  color:#aaa;
  text-decoration:line-through;
  font-size:16px;
}

.sop-savings{
  font-size:12px;
  font-weight:600;
  color:#27ae60;
  background:#eafaf1;
  padding:3px 10px;
  border-radius:100px;
}

.sop-tax-note{
  font-size:12px;
  color:#aaa;
  margin-top:6px;
}

.sop-countdown{
  display:flex;
  flex-direction:column;
  gap:20px;
  background:#1c1c1c;
  color:#fff;
  padding:12px;
}

.sop-countdown-left{
  display:flex;
  flex-direction:column;
  gap:20px;
}

.sop-countdown-heading{
  font-size:18px;
}

.sop-badge-wrap{
  display:inline-flex;
  align-items:center;
  justify-content:space-between;
  gap:20px;
  border:1.5px dashed #ffffff99;
}

.sop-badge-text{
  padding:21px 0 21px 8px;
  font-size:16px;
}

.sop-copy-btn {
    display: flex;
    align-items: center;
    gap: 8px;
    border: 0;
    background: #fff;
    color: #1c1c1c;
    font-size: 14px;
    padding: 12px 57px;
    margin: 8px 8px 8px 0;
    cursor: pointer;
}

.sop-timer{
  display:grid;
  grid-template-columns:repeat(4,1fr);
  gap:12px;
}

.sop-time-box{
  background:#fff;
  color:#111;
  text-align:center;
  padding:4px 14px;
  width:73px;
