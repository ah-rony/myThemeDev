/* for image cursor */

.sop-image-wrap{
  position:relative;
  overflow:hidden;
  cursor:none;
}

.sop-zoom-cursor{
  position:fixed;
  top:0;
  left:0;
  z-index:9999;
  pointer-events:none;
  transform:translate(-50%,-50%);
  padding:7px 14px;
  color:#fff;
  font-size:14px;
  font-weight:400;
  white-space:nowrap;
  opacity:0;
  visibility:hidden;
  transition:opacity .18s ease;
}

.sop-zoom-cursor.active{
  opacity:1;
  visibility:visible;
}



