<script>
document.addEventListener('DOMContentLoaded', () => {

  document.querySelectorAll('.sop-qty-wrap').forEach((wrap) => {

    const input = wrap.querySelector('.sop-qty-input');
    const minus = wrap.querySelector('.sop-minus');
    const plus = wrap.querySelector('.sop-plus');

    minus?.addEventListener('click', () => {
      if (parseInt(input.value) > 1) {
        input.value = parseInt(input.value) - 1;
      }
    });

    plus?.addEventListener('click', () => {
      input.value = parseInt(input.value) + 1;
    });
  });

  document.querySelectorAll('.sop-size-btn:not(.sold-out)').forEach((btn) => {
    btn.addEventListener('click', () => {
      btn.closest('.sop-size-list')
        .querySelectorAll('.sop-size-btn')
        .forEach((item) => item.classList.remove('active'));

      btn.classList.add('active');
    });
  });

  document.querySelectorAll('.sop-variant-btn:not(.sold-out)').forEach((btn) => {
    btn.addEventListener('click', () => {
      btn.closest('.sop-variant-list')
        .querySelectorAll('.sop-variant-btn')
        .forEach((item) => item.classList.remove('active'));

      btn.classList.add('active');
    });
  });

  document.querySelectorAll('.sop-accordion-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      btn.closest('.sop-accordion').classList.toggle('open');
    });
  });

  const overlay = document.querySelector('.sop-size-overlay');
  const drawer = document.querySelector('.sop-size-drawer');

  document.getElementById('sop-open-size-guide')?.addEventListener('click', () => {
    overlay.classList.add('active');
    drawer.classList.add('active');
  });

  document.querySelector('.sop-close-drawer')?.addEventListener('click', () => {
    overlay.classList.remove('active');
    drawer.classList.remove('active');
  });

  overlay?.addEventListener('click', () => {
    overlay.classList.remove('active');
    drawer.classList.remove('active');
  });

  document.querySelectorAll('.sop-copy-btn').forEach((btn) => {

    btn.addEventListener('click', () => {

      navigator.clipboard.writeText(btn.dataset.copy);

      const original = btn.innerHTML;

      btn.innerHTML = '✓ Copied';

      setTimeout(() => {
        btn.innerHTML = original;
      }, 1500);

    });

  });

  document.querySelectorAll('.sop-timer').forEach((timer) => {

    let total = 0;

    total += parseInt(timer.dataset.days || 0) * 86400;
    total += parseInt(timer.dataset.hours || 0) * 3600;
    total += parseInt(timer.dataset.mins || 0) * 60;
    total += parseInt(timer.dataset.secs || 0);

    const d = timer.querySelector('.sop-days');
    const h = timer.querySelector('.sop-hours');
    const m = timer.querySelector('.sop-mins');
    const s = timer.querySelector('.sop-secs');

    const pad = (n) => String(n).padStart(2, '0');

    const tick = () => {

      d.textContent = pad(Math.floor(total / 86400));
      h.textContent = pad(Math.floor((total % 86400) / 3600));
      m.textContent = pad(Math.floor((total % 3600) / 60));
      s.textContent = pad(Math.floor(total % 60));

      if (total > 0) {
        total--;
      }
    };

    tick();
    setInterval(tick, 1000);

  });

});




const zoomCursor = document.getElementById('sop-zoom-cursor');

document.querySelectorAll('.sop-image-wrap').forEach((item) => {

  item.addEventListener('mouseenter', () => {
    zoomCursor.classList.add('active');
  });

  item.addEventListener('mouseleave', () => {
    zoomCursor.classList.remove('active');
  });

  item.addEventListener('mousemove', (e) => {
    zoomCursor.style.left = e.clientX + 'px';
    zoomCursor.style.top  = e.clientY + 'px';
  });

});


</script>

