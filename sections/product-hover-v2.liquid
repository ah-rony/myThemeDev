{% style %}
.cs-v2-section-{{ section.id }} {
  padding: 40px 0;
}

.cs-v2-image-wrap {
  position: relative;
}

.cs-v2-card img {
  width: 100%;
  display: block;
}

.cs-v2-hover-image {
  position: absolute;
  top: 0;
  left: 0;
  opacity: 0;
  transition: opacity 0.3s ease;
}

.cs-v2-image-wrap:hover .cs-v2-hover-image {
  opacity: 1;
}

.cs-v2-swatches {
  display: flex;
  gap: 6px;
  margin: 8px 4px;
}

.cs-v2-swatch {
  width: 42px;
  height: 42px;
  border: 1px solid #ddd;
  cursor: pointer;
  overflow: hidden;
}

.cs-v2-swatch img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.cs-v2-swatch.is-active {
  outline: 2px solid black;
}

.cs-v2-variant-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.cs-v2-size-select {
  padding: 6px 10px;
  border: 1px solid #ddd;
  background: white;
  cursor: pointer;
  font-size: 14px;
  border-radius:0;
}

.cs-v2-size-dropdown {
  position: relative;
  min-width: 100px;
}

.cs-v2-size-selected {
  padding: 6px 10px;
  border: 1px solid #ddd;
  background: #fff;
  cursor: pointer;
}

/* UPWARD DROPDOWN */
.cs-v2-size-options {
  position: absolute;
  bottom: 100%;
  left: 0;
  width: 100%;
  background: #fff;
  border: 1px solid #ddd;
  display: none;
  z-index: 10;
}

.cs-v2-size-dropdown.active .cs-v2-size-options {
  display: block;
}

.cs-v2-size-option {
  padding: 6px 10px;
  cursor: pointer;
}

.cs-v2-size-option:hover {
  background: #f2f2f2;
}

/* prevent cut issue */
.cs-v2-card {
  overflow: visible;
}




.cs-v2-add-btn {
  position: absolute;
  bottom: 10px;
  left: 50%;
  transform: translateX(-50%);
  background: black;
  color: white;
  padding: 10px 16px;
  font-size: 14px;
  text-decoration: none;
  opacity: 0;
  transition: 0.3s ease;
}

.cs-v2-image-wrap:hover .cs-v2-add-btn {
  opacity: 1;
}

.cs-v2-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  background: green;
  color: white;
  font-size: 12px;
  font-weight: bold;
  padding: 6px 10px;
  z-index: 2;
}

.cs-v2-price {
  display: flex;
  align-items: center;
  gap: 8px;
}

.cs-v2-price-current {
  font-weight: bold;
  color: black;
}

.cs-v2-price-compare {
  text-decoration: line-through;
  color: #888;
  font-size: 14px;
}


.cs-v2-quickview-btn {
  position: absolute;
  top: 10px;
  right: 10px;
  width: 34px;
  height: 34px;
  background: white;
  border: 1px solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  opacity: 0;
  transform: scale(0.9);
  transition: 0.3s ease;
  z-index: 3;
}

.cs-v2-image-wrap:hover .cs-v2-quickview-btn {
  opacity: 1;
  transform: scale(1);
}

.cs-v2-quickview-btn svg {
  fill: black;
}

{% endstyle %}

<div class="cs-v2-section cs-v2-section-{{ section.id }}">
  <h2>{{ section.settings.title }}</h2>

  {% for block in section.blocks %}
    <h3>{{ block.settings.tab_title }}</h3>

    <div class="swiper">
      <div class="swiper-wrapper">

        {% for product in block.settings.collection.products %}
          <div class="swiper-slide">

            <div class="cs-v2-card">

              <div class="cs-v2-image-wrap">

              <button class="cs-v2-quickview-btn" data-handle="{{ product.handle }}">
                <span class="cs-v2-eye-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 511.999 511.999">
                    <g>
                      <path d="M508.745 246.041c-4.574-6.257-113.557-153.206-252.748-153.206S7.818 239.784 3.249 246.035a16.896 16.896 0 0 0 0 19.923c4.569 6.257 113.557 153.206 252.748 153.206s248.174-146.95 252.748-153.201a16.875 16.875 0 0 0 0-19.922zM255.997 385.406c-102.529 0-191.33-97.533-217.617-129.418 26.253-31.913 114.868-129.395 217.617-129.395 102.524 0 191.319 97.516 217.617 129.418-26.253 31.912-114.868 129.395-217.617 129.395z"/>
                      <path d="M255.997 154.725c-55.842 0-101.275 45.433-101.275 101.275s45.433 101.275 101.275 101.275S357.272 311.842 357.272 256s-45.433-101.275-101.275-101.275zm0 168.791c-37.23 0-67.516-30.287-67.516-67.516s30.287-67.516 67.516-67.516 67.516 30.287 67.516 67.516-30.286 67.516-67.516 67.516z"/>
                    </g>
                  </svg>
                </span>
              </button>

                {% if product.compare_at_price > product.price %}
                  {% assign discount = product.compare_at_price | minus: product.price %}
                  {% assign discount_percent = discount | times: 100 | divided_by: product.compare_at_price %}

                  <div class="cs-v2-badge">
                    -{{ discount_percent | round }}%
                  </div>
                {% endif %}

                <a href="{{ product.url }}">

                  <img
                    class="cs-v2-main-image"
                    src="{{ product.images[0] | image_url: width: 600 }}"
                    width="600"
                    height="600"
                    alt="{{ product.title }}"
                  >

                  {% if product.images[1] %}
                    <img
                      class="cs-v2-hover-image"
                      src="{{ product.images[1] | image_url: width: 600 }}"
                      width="600"
                      height="600"
                      alt="{{ product.title }}"
                    >
                  {% endif %}

                </a>

                <a href="{{ product.url }}" class="cs-v2-add-btn">
                  Add to Cart
                </a>
              </div>

              <h3>{{ product.title }}</h3>

              {% assign variant = product.selected_or_first_available_variant %}

              <p class="cs-v2-price">
                <span class="cs-v2-price-current">
                  {{ variant.price | money }}
                </span>

                {% if variant.compare_at_price > variant.price %}
                  <span class="cs-v2-price-compare">
                    {{ variant.compare_at_price | money }}
                  </span>
                {% endif %}
              </p>

              <div class="cs-v2-variant-row">

                {% assign color_index = nil %}
                {% for option in product.options_with_values %}
                  {% if option.name == 'Color' or option.name == 'Colour' %}
                    {% assign color_index = forloop.index0 %}
                  {% endif %}
                {% endfor %}

                <div class="cs-v2-swatches">  
                  {% assign shown = '' %}

                  {% for variant in product.variants %}
                    {% assign value = variant.options[color_index] %}

                    {% unless shown contains value %}

                      <button
                        class="cs-v2-swatch"
                        data-main="{{ variant.image | image_url: width: 600 }}"
                        data-hover="{% if variant.images.size > 1 %}{{ variant.images[1] | image_url: width: 600 }}{% else %}{{ product.images[1] | image_url: width: 600 }}{% endif %}"
                      >

                        {% if variant.image %}
                          <img src="{{ variant.image | image_url: width: 80 }}" width="80" height="80">
                        {% else %}
                          <img src="{{ product.images[0] | image_url: width: 80 }}" width="80" height="80">
                        {% endif %}

                      </button>

                      {% assign shown = shown | append: value | append: ',' %}
                    {% endunless %}
                  {% endfor %}
                </div>

                {% assign size_index = nil %}
                {% for option in product.options_with_values %}
                  {% if option.name == 'Size' or option.name == 'SIZE' %}
                    {% assign size_index = forloop.index0 %}
                  {% endif %}
                {% endfor %}

                {% comment %} {% if size_index != nil %}
                  <div class="cs-v2-size-wrap">
                  <select class="cs-v2-size-select">
                    {% assign shown_sizes = '' %}

                    {% for variant in product.variants %}
                      {% assign size = variant.options[size_index] %}

                      {% unless shown_sizes contains size %}
                        <option value="{{ variant.id }}">
                          {{ size }}
                        </option>

                        {% assign shown_sizes = shown_sizes | append: size | append: ',' %}
                      {% endunless %}
                    {% endfor %}
                  </select>
                  </div>
                {% endif %} {% endcomment %}

                {% if size_index != nil %}
                  <div class="cs-v2-size-dropdown">
                    <div class="cs-v2-size-selected">Select Size</div>

                    <div class="cs-v2-size-options">
                      {% assign shown_sizes = '' %}

                      {% for variant in product.variants %}
                        {% assign size = variant.options[size_index] %}

                        {% unless shown_sizes contains size %}
                          <div 
                            class="cs-v2-size-option"
                            data-id="{{ variant.id }}"
                          >
                            {{ size }}
                          </div>

                          {% assign shown_sizes = shown_sizes | append: size | append: ',' %}
                        {% endunless %}
                      {% endfor %}
                    </div>
                  </div>
                {% endif %}

              </div>

            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endfor %}
  {% render 'cs-quickview' %}
</div>


{% schema %}
{
  "name": "Collection Swatch",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Products",
      "label": "Title"
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Collection",
      "settings": [
        {
          "type": "text",
          "id": "tab_title",
          "label": "Title"
        },
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
  "presets": [
    { "name": "Product Hover V2" }
  ]
}
{% endschema %}