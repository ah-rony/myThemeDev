<div class="sop-latest-insights-inner container">

  <div class="col-12 sop-latest-insights-cover">

    <div class="sop-latest-insights-cover-wrap">

      {% if section.settings.sop_latest_cover_img != blank %}
        <img
          class="sop-latest-insights-cover-img"
          src="{{ section.settings.sop_latest_cover_img | image_url: width: 1200 }}"
          alt="{{ section.settings.sop_latest_cover_img.alt | escape }}"
          width="1200"
          height="{{ 1200 | divided_by: section.settings.sop_latest_cover_img.aspect_ratio | round }}"
          loading="lazy">
      {% else %}
        <div class="sop-latest-insights-cover-placeholder">
          {{ 'image' | placeholder_svg_tag: 'sop-latest-insights-placeholder-svg' }}
        </div>
      {% endif %}

      {% if section.settings.quote != blank %}
        <div class="sop-latest-insights-cover-info">

          <p class="sop-latest-insights-cover-text">
            {{ section.settings.quote }}
          </p>

          {% if section.settings.author != blank %}
            <span class="sop-latest-insights-cover-author">
              · {{ section.settings.author }}
            </span>
          {% endif %}

        </div>
      {% endif %}

    </div>

  </div>

  <div class="col-12">

    <div class="sop-latest-insights-slider" id="sop-slider-{{ section.id }}">

      {% for block in section.blocks %}
        {% assign article = block.settings.article %}

        {% if article != blank %}

          <a
            href="{{ article.url }}"
            class="sop-latest-insights-card"
            {{ block.shopify_attributes }}>

            <div class="sop-latest-insights-card-image-wrap">

              {% if article.image %}
                <img
                  class="sop-latest-insights-card-image"
                  src="{{ article.image | image_url: width: 900 }}"
                  alt="{{ article.title | escape }}"
                  width="900"
                  height="{{ 900 | divided_by: article.image.aspect_ratio | round }}"
                  loading="lazy">
              {% else %}
                <div class="sop-latest-insights-card-placeholder">
                  {{ 'image' | placeholder_svg_tag: 'sop-latest-insights-placeholder-svg' }}
                </div>
              {% endif %}

              <span class="sop-latest-insights-card-arrow">

                <svg width="15" height="15" viewBox="0 0 17 17" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M0.75 15.75L15.75 0.75M15.75 12V0.75H4.5" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>


              </span>

              <div class="sop-latest-insights-card-content">

                <span class="sop-latest-insights-card-date">
                  {{ article.published_at | date: "%b %d, %Y" }}
                </span>

                <h3 class="sop-latest-insights-card-title">
                  {{ article.title }}
                </h3>

              </div>

            </div>

          </a>

        {% endif %}
      {% endfor %}

    </div>

    <div class="sop-latest-insights-scrollbar">

      <div class="sop-latest-insights-scrollbar-track">

        <div class="sop-latest-insights-scrollbar-thumb" id="sop-thumb-{{ section.id }}"></div>

      </div>

    </div>

    <div class="sop-latest-insights-btn-wrap">

      {% assign blog = blogs[section.settings.blog] %}

      <a href="{{ blog.url }}" class="sop-latest-insights-btn">
        {{ section.settings.button_text }}
      </a>

    </div>

  </div>

</div>

<style>
     .sop-latest-insights * {
    box-sizing: border-box;
  }

  .sop-latest-insights-cover-wrap {
    position: relative;
    height: 200px;
    overflow: hidden;
  }

  .sop-latest-insights-cover-img,
  .sop-latest-insights-cover-placeholder {
    width: 100%;
    height: 340px;
    display: block;
    object-fit: cover;
    background: #ddd;
  }

  .sop-latest-insights-cover-info {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 12px;
    background: linear-gradient(to top, rgba(0,0,0,.88), rgba(0,0,0,.35), transparent);
    text-align: right;
  }

  .sop-latest-insights-cover-text {
    margin: 0 0 16px;
    color: #fff;
    font-size: 14px;
    line-height: 100%;
  }

  .sop-latest-insights-cover-author {
    color: #fff;
    font-size: 16px;
    font-weight: 300;
  }

  .sop-latest-insights-slider {
    display: flex;
    overflow-x: auto;
    gap: 0;
    width: 100%;
    padding: 20px 0 10px;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .sop-latest-insights-slider::-webkit-scrollbar {
    display: none;
  }

  .sop-latest-insights-card {
    position: relative;
    min-width: 100%;
    width: 100%;
    flex: 0 0 100%;
    scroll-snap-align: start;
    text-decoration: none;
    color: #fff;
    display: block;
  }

  .sop-latest-insights-card-image-wrap {
    position: relative;
    overflow: hidden;
    width: 100%;
    margin-bottom: 30px;
  }

  .sop-latest-insights-card-image,
  .sop-latest-insights-card-placeholder {
    width: 100%;
    height: 364px;
    object-fit: cover;
    display: block;
    background: #ddd;
  }

  .sop-latest-insights-card-image {
    transition: transform 0.5s ease;
  }

  .sop-latest-insights-card:hover .sop-latest-insights-card-image {
    transform: scale(1.03);
  }

  .sop-latest-insights-card-content {   
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 16px 20px;
  }

  .sop-latest-insights-card-date {
    display: block;
    margin-bottom: 12px;
    font-size: 18px;
    font-weight: 400;
    color: #FFFFFFE5;
  }

  .sop-latest-insights-card-title {
    margin: 0;
    font-size: 20px;
    line-height: 100%;
    color: #fff;
  }

  .sop-latest-insights-card-arrow {
    position: absolute;
    top: 16px;
    right: 20px;
    width: 32px;
    height: 32px;
    background: #1c1c1c;
    backdrop-filter:blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    z-index: 2;
  }

  .sop-latest-insights-scrollbar {
    padding: 10px 0;
    margin-top: 30px;
  }

  .sop-latest-insights-scrollbar-track {
    position: relative;
    width: 100%;
    height: 6px;
    background: #d6d6d6;
    overflow: hidden;
    border-radius: 6px;
  }

  .sop-latest-insights-scrollbar-thumb {
    position: absolute;
    left: 0;
    top: 0;
    height: 100%;
    width: 25%;
    background: #111;
    border-radius: 6px;
    transition: transform 0.1s linear;
  }

  .sop-latest-insights-btn-wrap {
    padding-top: 40px;
  }

  .sop-latest-insights-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 56px;
    background: #111;
    color: #fff;
    text-decoration: none;
    font-size: 14px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }


  @media screen and (min-width: 768px) and (max-width: 833px) {

  .sop-latest-insights {
    padding: 0;
  }

  .sop-latest-insights-inner {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sop-latest-insights-cover {
    width: 100%;
    position: static;
    height: auto;
    padding: 0;
    margin-bottom: 2px;
  }

  .sop-latest-insights-cover-wrap {
    height: 200px;
    margin-bottom: 30px;
  }

  .sop-latest-insights-cover-img,
  .sop-latest-insights-cover-placeholder {
    height: 200px;
  }

  .sop-latest-insights-cover-info {
    padding: 24px 32px;
  }

  .sop-latest-insights-cover-text {
    font-size: 16px;
  }

  .sop-latest-insights-cover-author {
    font-size: 14px;
  }

  .sop-latest-insights-inner > .col-12:last-child {
    width: 100%;
    padding: 0;
  }

  .sop-latest-insights-slider {
    display: flex;
    flex-wrap: wrap;
    overflow: visible;
    padding: 0;
    scroll-snap-type: none;
    gap: 0;
  }

  .sop-latest-insights-card {
    width: 50%;
    min-width: 50%;
    flex: 0 0 50%;
    scroll-snap-align: none;
    margin-bottom: 2px;
    padding-right: 0;
    padding-left: 0;
  }

  .sop-latest-insights-card:nth-child(odd) {
    padding-right: 1px;
  }

  .sop-latest-insights-card:nth-child(even) {
    padding-left: 1px;
  }

  .sop-latest-insights-card:last-child:nth-child(odd) {
    width: 100%;
    min-width: 100%;
    flex: 0 0 100%;
    padding-right: 0;
    padding-left: 0;
  }

  .sop-latest-insights-card:last-child:nth-child(odd) .sop-latest-insights-card-image,
  .sop-latest-insights-card:last-child:nth-child(odd) .sop-latest-insights-card-placeholder {
    height: 500px;
    margin-top: 24px;
  }

  .sop-latest-insights-card-image,
  .sop-latest-insights-card-placeholder {
    height: 450px;
    margin-bottom: 0;
  }

  .sop-latest-insights-card-arrow {
    display: none;
  }

  .sop-latest-insights-scrollbar {
    display: none;
  }

  .sop-latest-insights-btn-wrap {
    padding: 0;
    margin-top: 40px;
  }

  .sop-latest-insights-btn {
    min-height: 64px;
  }

}

@media screen and (min-width: 834px) {

  .sop-latest-insights {
    padding: 0;
  }

  .sop-latest-insights-inner {
    display: flex;
    flex-direction: row;
    align-items: flex-start;
    gap: 24px;
  }

  .sop-latest-insights-cover {
    width: 50%;
    flex: 0 0 50%;
    position: sticky;
    top: 0;
    height: 100vh;
    padding: 0;
    margin-bottom: 0;
  }

  .sop-latest-insights-cover-wrap {
    height: 100vh;
  }

  .sop-latest-insights-cover-img,
  .sop-latest-insights-cover-placeholder {
    height: 100vh;
  }

  .sop-latest-insights-cover-info {
    padding: 40px;
  }

  .sop-latest-insights-cover-text {
    font-size: 18px;
  }

  .sop-latest-insights-cover-author {
    font-size: 15px;
  }

  .sop-latest-insights-inner > .col-12:last-child {
    width: 50%;
    flex: 0 0 50%;
    padding: 0;
  }

  .sop-latest-insights-slider {
    display: block;
    overflow: visible;
    padding: 0;
    scroll-snap-type: none;
    flex-wrap: unset;
  }

  .sop-latest-insights-card {
    width: 100%;
    min-width: 100%;
    flex: unset;
    margin-bottom: 2px;
    padding-right: 0;
    padding-left: 0;
  }

  .sop-latest-insights-card:nth-child(odd) {
    padding-right: 0;
  }

  .sop-latest-insights-card:nth-child(even) {
    padding-left: 0;
  }

  .sop-latest-insights-card:last-child:nth-child(odd) {
    width: 100%;
    min-width: 100%;
    flex: unset;
    padding-right: 0;
    padding-left: 0;
  }

  .sop-latest-insights-card:last-child:nth-child(odd) .sop-latest-insights-card-image,
  .sop-latest-insights-card:last-child:nth-child(odd) .sop-latest-insights-card-placeholder {
    height: 500px;
  }

  .sop-latest-insights-card-image,
  .sop-latest-insights-card-placeholder {
    height: 500px;
    margin-bottom: 0;
  }

  .sop-latest-insights-card-arrow {
    display: none;
  }

  .sop-latest-insights-scrollbar {
    display: none;
  }

  .sop-latest-insights-btn-wrap {
    padding: 0;
    padding-top: 10px;
  }

  .sop-latest-insights-btn {
    min-height: 70px;
  }

}
</style>


<script>
      (function(){
  
  const slider = document.getElementById('sop-slider-{{ section.id }}');
  const thumb = document.getElementById('sop-thumb-{{ section.id }}');
  
  if(!slider || !thumb) return;
  
  function updateScrollbar(){
  
    const maxScroll = slider.scrollWidth - slider.clientWidth;
  
    if(maxScroll <= 0){
      thumb.style.width = '100%';
      return;
    }
  
    const visibleRatio = slider.clientWidth / slider.scrollWidth;
    const thumbWidth = visibleRatio * 100;
  
    thumb.style.width = thumbWidth + '%';
  
    const maxMove = slider.clientWidth - thumb.offsetWidth;
    const move = (slider.scrollLeft / maxScroll) * maxMove;
  
    thumb.style.transform = `translateX(${move}px)`;
  }
  
  slider.addEventListener('scroll', updateScrollbar, {
    passive:true
  });
  
  window.addEventListener('resize', updateScrollbar);
  
  updateScrollbar();
  
  })();
</script>

{% schema %}
  {
    "name": "Latest Insights",
    "tag": "section",
    "class": "sop-latest-insights",
    "settings": [
      {
        "type": "image_picker",
        "id": "sop_latest_cover_img",
        "label": "Cover Image"
      },
      {
        "type": "textarea",
        "id": "quote",
        "label": "Quote Text",
        "default": "\"I used to switch up my shoes frequently, but now I only wear these. They match in my wardrobe!\""
      },
      {
        "type": "text",
        "id": "author",
        "label": "Author Name",
        "default": "Maya L. / St. Paul, MN"
      },
      {
        "type": "blog",
        "id": "blog",
        "label": "Blog"
      }, {
        "type": "text",
        "id": "button_text",
        "label": "Button Text",
        "default": "Explore More Insights"
      }
    ],
    "blocks": [
      {
        "type": "article",
        "name": "Article",
        "settings": [
          {
            "type": "article",
            "id": "article",
            "label": "Select Article"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Latest Insights"
      }
    ],
    "max_blocks": 10
  }
{% endschema %}