{% style %}
.new-arrivals {
  padding: 40px 0;
}

.new-arrivals-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.tabs {
  display: flex;
  gap: 15px;
  overflow-x: auto;
}

.tab-btn {
  border: none;
  background: none;
  cursor: pointer;
  padding: 8px;
}

.tab-btn.active {
  color: red;
  font-weight: bold;
}

.tab-content {
  display: none;
}

.tab-content.active {
  display: block;
}




/* css for cards */


.color-swatches {
  display: flex;
  gap: 6px;
  margin-top: 8px;
}

.color-swatch {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 1px solid #ccc;
  cursor: pointer;
}

.color-swatch.active {
  border: 2px solid black;
  transform: scale(1.1);
}

.product-main-image {
  width: 100%;
  height: auto;
  display: block;
}


