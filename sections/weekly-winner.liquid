{% liquid
  assign sop_product = section.settings.product | default: product

  assign sop_mt = section.settings.margin_top | times: 0.0625
  assign sop_mb = section.settings.margin_bottom | times: 0.0625
  assign sop_pt = section.settings.padding_top | times: 0.0625
  assign sop_pb = section.settings.padding_bottom | times: 0.0625
%}

<div class="sop-weekly-winner" data-lenis-prevent>
  <div class="sop-container">
    <div class="sop-row">

      <div class="sop-col-images">
        <div class="sop-stack">

          {% for image in sop_product.images %}
            <div class="sop-card">
              {{ image
 | image_url: width: 1600
 | image_tag:
 loading: 'lazy',
 alt: image.alt | default: sop_product.title
              }}
            </div>
          {% else %}
            <div class="sop-card">
              {{ 'product-1' | placeholder_svg_tag }}
            </div>
          {% endfor %}

        </div>
      </div>

      <div class="sop-col-info">
        <div class="sop-info">
          <div class="sop-info-inner">
            <h1 class="sop-title">
              {{ sop_product.title }}
            </h1>
          </div>
        </div>
      </div>

    </div>
  </div>
</div>

{% style %}
  .sop-weekly-winner *,
  .sop-weekly-winner *::before,
  .sop-weekly-winner *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .sop-weekly-winner {
    margin-block: {{ sop_mt }}rem{{ sop_mb }}rem;
    padding-block: {{ sop_pt }}rem{{ sop_pb }}rem;
  }

  .sop-container {
    width: 100%;
    max-width: 1440px;
    margin-inline: auto;
    padding-inline: 16px;
  }

  .sop-row {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .sop-col-images,
  .sop-col-info {
    width: 100%;
  }

  .sop-stack {
    position: relative;
    height: 60vh;
    overflow-y: scroll;
    scroll-snap-type: y mandatory;
    -webkit-overflow-scrolling: touch;
    border-radius: {{ section.settings.card_radius | times: 0.0625 }}rem;
    background: #f4f4f2;
    scroll-behavior: smooth;
  }

  .sop-stack::-webkit-scrollbar {
    display: none;
  }
  .sop-stack {
    scrollbar-width: none;
  }

  .sop-card {
    scroll-snap-align: start;
    scroll-snap-stop: always;
    width: 100%;
    height: 60vh;
    overflow: hidden;
    flex-shrink: 0;
  }

  .sop-card img,
  .sop-card svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sop-info {
    background: #fff;
  }

  .sop-info-inner {
    padding: 20px 16px;
  }

  .sop-title {
    font-size: 22px;
    font-weight: 600;
    line-height: 1.2;
  }

  @media (min-width: 1024px) {
    .sop-container {
      padding-inline: 32px;
    }

    .sop-row {
      flex-direction: row;
      align-items: stretch;
    }

    .sop-col-images {
      width: 58.333%;
      flex-shrink: 0;
    }

    .sop-col-info {
      width: 41.667%;
      flex-shrink: 0;
    }

    .sop-stack {
      height: 100vh;
    }

    .sop-card {
      height: 100vh;
    }

    .sop-info {
      position: sticky;
      top: 0;
      height: 100vh;
      overflow-y: auto;
    }

    .sop-info-inner {
      padding: 40px;
    }

    .sop-title {
      font-size: 34px;
    }

    .sop-row {
      min-height: 200vh;
    }

    .sop-col-images {
      position: sticky;
      top: 0;
      height: 100vh;
    }
  }
{% endstyle %}

<script>
  (function () {
  function initSopSnap() {
    document.querySelectorAll('.sop-weekly-winner').forEach(function (section) {
      const stack = section.querySelector('.sop-stack');
      const info  = section.querySelector('.sop-info');
  
      if (!stack) return;
  
      let isScrolling = false;
  
      const atStart = () => stack.scrollTop <= 0;
      const atEnd   = () => stack.scrollTop + stack.clientHeight >= stack.scrollHeight - 2;
  
      function handleWheel(e) {
        const goingDown = e.deltaY > 0;
  
        if (goingDown && atEnd())   return;
        if (!goingDown && atStart()) return;
  
        e.preventDefault();
  
        if (isScrolling) return;
        isScrolling = true;
  
        stack.scrollBy({
          top: (goingDown ? 1 : -1) * stack.clientHeight,
          behavior: 'smooth'
        });
  
        setTimeout(() => { isScrolling = false; }, 800);
      }
  
  
      // function isCentered() {
      //   const rect = section.getBoundingClientRect();
      //   const sectionCenter = rect.top + rect.height / 2;
      //   const viewportCenter = window.innerHeight / 2;
  
      //   return Math.abs(sectionCenter - viewportCenter) < 150;
      // }
  
      // function handleWheel(e) {
      //   if (!isCentered()) return;
  
      //   const goingDown = e.deltaY > 0;
  
      //   if (goingDown && atEnd()) return;
      //   if (!goingDown && atStart()) return;
  
      //   e.preventDefault();
  
      //   if (isScrolling) return;
      //   isScrolling = true;
  
      //   stack.scrollBy({
      //     top: (goingDown ? 1 : -1) * stack.clientHeight,
      //     behavior: 'smooth'
      //   });
  
      //   setTimeout(() => {
      //     isScrolling = false;
      //   }, 1200);
      // }
  
      stack.addEventListener('wheel', handleWheel, { passive: false });
      if (info) info.addEventListener('wheel', handleWheel, { passive: false });
    });
  }
  
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initSopSnap);
  } else {
    initSopSnap();
  }
  })();
</script>

{% schema %}
  {
    "name": "Weekly winner",
    "tag": "section",
    "class": "section-weekly-winner",
    "settings": [
      {
        "type": "product",
        "id": "product",
        "label": "Select product"
      },
      {
        "type": "range",
        "id": "card_radius",
        "label": "Card radius (px)",
        "min": 0,
        "max": 40,
        "step": 2,
        "default": 0
      },
      {
        "type": "range",
        "id": "margin_top",
        "label": "Margin top (px)",
        "min": 0,
        "max": 120,
        "step": 4,
        "default": 24
      },
      {
        "type": "range",
        "id": "margin_bottom",
        "label": "Margin bottom (px)",
        "min": 0,
        "max": 120,
        "step": 4,
        "default": 24
      }, {
        "type": "range",
        "id": "padding_top",
        "label": "Padding top (px)",
        "min": 0,
        "max": 120,
        "step": 4,
        "default": 32
      }, {
        "type": "range",
        "id": "padding_bottom",
        "label": "Padding bottom (px)",
        "min": 0,
        "max": 120,
        "step": 4,
        "default": 32
      }
    ],
    "presets": [
      {
        "name": "Weekly winner"
      }
    ]
  }
{% endschema %}